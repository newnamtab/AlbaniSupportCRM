@page "/"

@using Microsoft.AspNetCore.Authorization
@using WebApp.Auth

@attribute [Authorize]
@inject IAccountService AccountService

<PageTitle>Albani Support</PageTitle>

<h1 class="text-center"> Velkommen Lokale Verdensmænd</h1>
<div class="p-4">
    <div class="container">
        <h1>Hi @AccountService.User?.FirstName ?? "Guest"!</h1>
        <p>You're logged in with Blazor WebAssembly!!</p>
        <p><NavLink href="users">Manage Users</NavLink></p>
    </div>
</div>